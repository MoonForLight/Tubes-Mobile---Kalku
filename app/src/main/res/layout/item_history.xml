<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:background="@drawable/bg_card_rounded" android:gravity="center_vertical" android:orientation="horizontal" android:padding="14dp">
    <FrameLayout android:layout_width="46dp" android:layout_height="46dp" android:background="@drawable/bg_stat_orange" android:padding="11dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/ic_calculator" android:tint="@color/brown_primary" /></FrameLayout>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvProductName" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLines="1" android:text="Produk" android:textColor="@color/text_dark" android:textSize="15sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvDate" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Tanggal" android:textColor="@color/text_gray_light" android:textSize="11sp" />
        <TextView android:id="@+id/tvProfit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="+Rp0" android:textColor="@color/green_profit" android:textSize="11sp" android:textStyle="bold" />
    </LinearLayout>
    <TextView android:id="@+id/tvSellingPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:text="Rp0" android:textColor="@color/green_profit" android:textSize="14sp" android:textStyle="bold" />
    <ImageButton android:id="@+id/btnDelete" android:layout_width="38dp" android:layout_height="38dp" android:background="@android:color/transparent" android:contentDescription="Hapus" android:padding="8dp" android:src="@drawable/ic_delete" android:tint="#C34A3E" />
</LinearLayout>
