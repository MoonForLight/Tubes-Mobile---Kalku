<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="54dp"
    android:paddingEnd="28dp"
    android:paddingBottom="32dp">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_logo_square"
        android:padding="17dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Logo Kalku"
            android:src="@drawable/ic_calculator"
            android:tint="@color/white" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Kalku"
        android:textColor="@color/brown_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Simple Finance for MSMEs"
        android:textColor="@color/text_gray_light"
        android:textSize="13sp" />

    <ImageView
        android:layout_width="260dp"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="Ilustrasi toko UMKM"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_storefront" />

    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="88dp"
        android:layout_height="5dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/brown_primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:letterSpacing="0.18"
        android:text="INITIALIZING..."
        android:textColor="@color/text_gray_light"
        android:textSize="10sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="Grow your business with clarity."
        android:textColor="@color/text_dark"
        android:textSize="12sp" />

</LinearLayout>
