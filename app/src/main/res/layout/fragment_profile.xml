<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Profil"
            android:textColor="@color/text_dark"
            android:textSize="25sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="24dp">

            <TextView
                android:id="@+id/tvInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center"
                android:text="US"
                android:textColor="@color/brown_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivProfilePhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="Foto profil"
                android:scaleType="centerCrop"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Nama Pengguna"
            android:textColor="@color/text_dark"
            android:textSize="21sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBusinessName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Nama Usaha"
            android:textColor="@color/text_gray_light" />

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="email@example.com"
            android:textColor="@color/text_gray_light"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Nomor telepon belum diisi"
            android:textColor="@color/text_gray_light"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:gravity="center"
            android:text="Alamat usaha belum diisi"
            android:textColor="@color/text_gray_light"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_green"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTotalProfit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp0"
                    android:textColor="@color/green_profit"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total profit"
                    android:textColor="@color/text_gray_light"
                    android:textSize="11sp" />
            </LinearLayout>

<!--            <LinearLayout-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="match_parent"-->
<!--                android:layout_marginStart="6dp"-->
<!--                android:layout_weight="1"-->
<!--                android:background="@drawable/bg_stat_orange"-->
<!--                android:gravity="center"-->
<!--                android:orientation="vertical">-->

<!--                <TextView-->
<!--                    android:id="@+id/tvProductCount"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="0"-->
<!--                    android:textColor="@color/brown_primary"-->
<!--                    android:textSize="22sp"-->
<!--                    android:textStyle="bold" />-->

<!--                <TextView-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="Produk aktif"-->
<!--                    android:textColor="@color/text_gray_light"-->
<!--                    android:textSize="11sp" />-->
<!--            </LinearLayout>-->
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Kalku.Button.Primary"
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:text="Edit Informasi Bisnis"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Kalku.Button.Secondary"
            android:id="@+id/btnAppSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="Pengaturan Aplikasi"
            android:textAllCaps="false"
            android:textColor="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Kalku.Button.Secondary"
            android:id="@+id/btnHelp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="Pusat Bantuan"
            android:textAllCaps="false"
            android:textColor="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Kalku.Button.Danger"
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="@color/danger"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnDeleteAccount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/transparent"
            android:text="Hapus Akun dan Data"
            android:textAllCaps="false"
            android:textColor="@color/danger" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="KALKU VERSION 1.1"
            android:textColor="@color/text_hint"
            android:textSize="10sp" />
    </LinearLayout>
</ScrollView>
