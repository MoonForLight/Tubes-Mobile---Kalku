<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:contentDescription="Kembali"
                android:src="@drawable/ic_back" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tambah Produk"
                android:textColor="@color/text_dark"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivProductImage"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_image_placeholder"
                android:contentDescription="Foto produk"
                android:padding="18dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_storefront" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
            style="@style/Widget.Kalku.Button.Secondary"
                    android:id="@+id/btnChooseImage"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Pilih Foto Produk"
                    android:textAllCaps="false"
                    android:textColor="@color/brown_primary" />

                <Button
                    android:id="@+id/btnRemoveImage"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="6dp"
                    android:background="@android:color/transparent"
                    android:text="Hapus Foto"
                    android:textAllCaps="false"
                    android:textColor="@color/danger"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Nama Produk"
            android:textColor="@color/text_dark"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etProductName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="7dp"
            android:background="@drawable/bg_input_outline"
            android:hint="Contoh: Kopi Susu"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Kategori"
            android:textColor="@color/text_dark"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="7dp"
            android:background="@drawable/bg_input_outline"
            android:paddingHorizontal="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Biaya Produksi"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etProductionCost"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="7dp"
                    android:background="@drawable/bg_input_outline"
                    android:hint="Rp 0"
                    android:inputType="number"
                    android:paddingHorizontal="14dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Biaya Operasional"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etOperationalCost"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="7dp"
                    android:background="@drawable/bg_input_outline"
                    android:hint="Rp 0"
                    android:inputType="number"
                    android:paddingHorizontal="14dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jumlah Stok"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etQuantity"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="7dp"
                    android:background="@drawable/bg_input_outline"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:text="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Batas Stok Rendah"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etLowStockThreshold"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="7dp"
                    android:background="@drawable/bg_input_outline"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:text="5" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Target Keuntungan (%)"
            android:textColor="@color/text_dark"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etProfit"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="7dp"
            android:background="@drawable/bg_input_outline"
            android:inputType="numberDecimal"
            android:paddingHorizontal="16dp"
            android:text="25" />

        <Switch
            android:id="@+id/switchActive"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:checked="true"
            android:text="Produk aktif dan tampil di perhitungan"
            android:textColor="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Kalku.Button.Primary"
            android:id="@+id/btnSaveProduct"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="22dp"
            android:text="Tambah Produk"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
