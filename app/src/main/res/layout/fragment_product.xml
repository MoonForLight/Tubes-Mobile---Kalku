<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/screen_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="20dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kelola Produk" android:textColor="@color/text_dark" android:textSize="25sp" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Simpan biaya dan harga jual produk usaha Anda" android:textColor="@color/text_gray_light" android:textSize="13sp" />
        <EditText android:id="@+id/etSearch" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="16dp" android:background="@drawable/bg_input_outline" android:drawableStart="@drawable/ic_storefront" android:drawablePadding="10dp" android:hint="Cari produk atau kategori" android:paddingHorizontal="16dp" android:singleLine="true" android:textColor="@color/text_dark" android:textColorHint="@color/text_hint" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="90dp" android:layout_marginTop="14dp" android:background="@drawable/bg_card_orange" android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Nilai Produk" android:textColor="#FFF2E9" android:textSize="12sp" />
                <TextView android:id="@+id/tvInventoryValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Rp0" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout android:layout_width="90dp" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/tvProductCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/white" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Produk" android:textColor="#FFF2E9" android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
        <TextView android:id="@+id/emptyState" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center" android:text="Belum ada produk.\nTekan tombol + untuk menambahkan." android:textAlignment="center" android:textColor="@color/text_gray_light" />
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvProducts" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="10dp" android:layout_weight="1" android:visibility="gone" />
    </LinearLayout>
    <com.google.android.material.floatingactionbutton.FloatingActionButton android:id="@+id/fabAddProduct" android:layout_width="56dp" android:layout_height="56dp" android:layout_gravity="bottom|end" android:layout_margin="20dp" android:contentDescription="Tambah produk" app:backgroundTint="@color/brown_primary" app:srcCompat="@drawable/ic_add" />
</FrameLayout>
