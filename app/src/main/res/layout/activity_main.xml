<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <FrameLayout
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/bg_logo_square"
        android:padding="16dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Logo Kalku"
            android:src="@drawable/ic_calculator"
            android:tint="@color/white" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="Halo, Pengguna!"
        android:textColor="@color/text_dark"
        android:textSize="27sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Fitur kalkulator harga jual sudah siap digunakan."
        android:textColor="@color/text_gray_light"
        android:textSize="14sp" />

    <ImageView
        android:layout_width="230dp"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:contentDescription="Ilustrasi perhitungan"
        android:src="@drawable/ic_chart_up" />

    <Button
        android:id="@+id/btnOpenCalculator"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_button_primary"
        android:backgroundTint="@null"
        android:text="Mulai Hitung Harga Jual"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnOpenHistory"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_secondary"
        android:backgroundTint="@null"
        android:text="Lihat Riwayat Perhitungan"
        android:textAllCaps="false"
        android:textColor="@color/brown_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
