<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Kalku.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/brown_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="Widget.Kalku.Button.Secondary" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/brown_primary</item>
        <item name="backgroundTint">@color/card_background</item>
        <item name="strokeColor">@color/brown_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="Widget.Kalku.Button.Danger" parent="Widget.Kalku.Button.Secondary">
        <item name="android:textColor">@color/danger</item>
        <item name="strokeColor">@color/danger</item>
    </style>

    <style name="Widget.Kalku.Button.Circle" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/brown_primary</item>
        <item name="backgroundTint">@color/orange_soft</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
    </style>
</resources>
